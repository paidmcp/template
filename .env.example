# Receiver wallet (same address works on Base and Plasma)
SEED_PHRASE=""

# test = Base Sepolia defaults; live = Base/Plasma mainnet defaults
NETWORK_MODE="test"

# RPC endpoints
BASE_RPC_URL="https://sepolia.base.org"
PLASMA_RPC_URL="https://rpc.plasma.to"

# Token contracts
# USDC on Base Sepolia (for NETWORK_MODE=test)
USDC_ADDRESS="0x036CbD53842c5426634e7929541eC2318f3dCF7e"
# USDT0 on Plasma mainnet
USDT0_ADDRESS="0xB8CE59FC3717ada4C02eaDF9682A9e934F625ebb"

# Facilitators (set URL to "" to disable a network)
# Leave empty to use mode defaults:
# - test: https://facilitator.x402.org
# - live: https://api.cdp.coinbase.com/platform/v2/x402
BASE_FACILITATOR_URL=""
# Plasma: Semantic facilitator
PLASMA_FACILITATOR_URL=""

# Free unpaid calls per payer (x402-payer header)
FREE_TRIAL_CALLS="10"

# Required when BASE_FACILITATOR_URL points to Coinbase CDP
CDP_API_KEY_ID=""
CDP_API_KEY_SECRET=""

# Server
PORT="4021"

# Optional for AI-powered tools in forks
ANTHROPIC_API_KEY=""

# Optional DB override. On Fly set DB_PATH=/app/data/paidmcp.db (mounted volume).
DB_PATH="./paidmcp.db"
