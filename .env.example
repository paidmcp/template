# Receiver wallet (same address works on Base and Plasma)
SEED_PHRASE=""

# RPC endpoints
BASE_RPC_URL="https://mainnet.base.org"
PLASMA_RPC_URL="https://rpc.plasma.to"

# Token contracts
USDC_ADDRESS="0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913"
USDT0_ADDRESS="0xB8CE59FC3717ada4C02eaDF9682A9e934F625ebb"

# Facilitators (set URL to "" to disable a network)
# Base: Coinbase CDP facilitator (recommended)
BASE_FACILITATOR_URL="https://api.cdp.coinbase.com/platform/v2/x402"
# Plasma: Semantic facilitator
PLASMA_FACILITATOR_URL="https://x402.semanticpay.io/"

# Required when BASE_FACILITATOR_URL points to Coinbase CDP
CDP_API_KEY_ID=""
CDP_API_KEY_SECRET=""

# Server
PORT="4021"

# Optional for AI-powered tools in forks
ANTHROPIC_API_KEY=""

# Optional DB override. On Fly set DB_PATH=/app/data/paidmcp.db (mounted volume).
DB_PATH="./paidmcp.db"
