{
  "name": "paidmcp-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Forkable template for paid MCP servers with x402 and Tether WDK.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md,yml,yaml}\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,yml,yaml}\"",
    "check": "npm run lint && npm run typecheck && npm run build",
    "wallet:create": "tsx src/scripts/wallet-create.ts",
    "wallet:info": "tsx src/scripts/wallet-info.ts",
    "calls:recent": "tsx src/scripts/calls-recent.ts"
  },
  "dependencies": {
    "@coinbase/x402": "^2.1.0",
    "@tetherto/wdk-wallet-evm": "^1.0.0-beta.12",
    "@x402/core": "^2.13.0",
    "@x402/evm": "^2.13.0",
    "@x402/express": "^2.13.0",
    "better-sqlite3": "^12.10.0",
    "bip39": "^3.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "tsx": "^4.22.3",
    "typescript-eslint": "^8.46.4",
    "typescript": "^6.0.3"
  }
}
